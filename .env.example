# --- TELEGRAM BOT CONFIG ---
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321
REQUIRED_CHANNEL_ID=-1001234567890

# --- ENABLED PROTOCOLS ---
ENABLE_XUI=true
ENABLE_STRONGSWAN=true

# --- DATABASE CONFIG (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=vpn_bot_db

# --- 3X-UI PANEL CONFIG ---
XUI_URL=http://your_panel_ip:2053
XUI_USER=admin
XUI_PASSWORD=your_panel_password

# --- STRONGSWAN CONFIG ---
# Если управляем через БД напрямую (рекомендуется), данные совпадут с DB CONFIG.
# Если через SSH-команды:
SSH_HOST=your_server_ip
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=/path/to/private/key

# --- PAYMENT CONFIG (CryptoBot) ---
CRYPTO_BOT_TOKEN=your_cryptobot_api_token_here
IS_NET_TEST=true

# Валюта приема оплат (USDT, TON, BTC, NOT)
PAYMENT_CURRENCY=USDT

# Цены для тарифа БАЗОВЫЙ (в указанной выше валюте)
PRICE_BASE_1_MONTH=3
PRICE_BASE_3_MONTHS=7.5
PRICE_BASE_6_MONTHS=14

# Цены для тарифа PREMIUM (с поддержкой нативного IKEv2)
PRICE_PREMIUM_1_MONTH=5
PRICE_PREMIUM_3_MONTHS=13.5
PRICE_PREMIUM_6_MONTHS=25

# Имя вашего VPN-сервиса для вывода в Telegram
BRAND_NAME=Overlord VPN
